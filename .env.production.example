# DungeonMasterONE Production Environment
# Copy to .env on the VPS at /opt/dm1/.env
# NEVER commit real values to git

# Domain
DOMAIN=dm1.yourdomain.com
ACME_EMAIL=your@email.com

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# MongoDB
MONGO_USER=dm1
MONGO_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT Auth (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_64_CHAR_HEX

# Google AI (Gemini)
GOOGLE_AI_API_KEY=your-gemini-api-key

# Hume AI TTS (future)
HUME_API_KEY=
HUME_SECRET_KEY=

# Google OAuth (future)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
